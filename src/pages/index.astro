---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Memento Convivium — Cene con Delitto a Tema Storico"
  description="Un banchetto nell'antica Roma. Un ospite trovato morto. Sei tu il prossimo? Scopri le cene con delitto di Memento Convivium."
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-columns" aria-hidden="true">
      <div class="column"></div>
      <div class="column"></div>
      <div class="column"></div>
    </div>
    <div class="hero-vignette" aria-hidden="true"></div>

    <div class="hero-content">
      <span class="section-label animate" style="--d:0.1s">MMXXVI · Roma Antica</span>
      <h1 class="hero-title animate" style="--d:0.25s">
        Il Banchetto<br /><em>degli Dèi</em><br />nasconde un segreto
      </h1>
      <div class="divider animate" style="--d:0.4s">
        <span>⬥</span>
      </div>
      <p class="hero-sub animate" style="--d:0.5s">
        Sei invitato a una cena nell'antica Roma.<br />
        Prima che la notte finisca, qualcuno sarà accusato di omicidio.<br />
        <em>Forse tu.</em>
      </p>
      <div class="hero-ctas animate" style="--d:0.65s">
        <a href="#eventi" class="btn-primary">Scopri gli eventi</a>
        <a href="#come-funziona" class="btn-ghost">Come funziona</a>
      </div>
    </div>

    <div class="hero-scroll animate" style="--d:1s">
      <span>Scorri</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- INTRO QUOTE -->
  <section class="quote-section">
    <div class="container">
      <blockquote class="quote">
        <span class="quote-mark">"</span>
        <p>
          In convivio loquere et de absente ne loquare.<br />
          <em>A banchetto parla, ma non parlare di chi è assente.</em>
        </p>
        <cite>— Publio Siro, Sententiae</cite>
      </blockquote>
    </div>
  </section>

  <!-- COME FUNZIONA -->
  <section class="section come-funziona" id="come-funziona">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Il rituale</span>
        <h2>Come funziona</h2>
        <div class="divider"><span>⬥</span></div>
      </div>

      <div class="steps">
        <div class="step">
          <div class="step-num">I</div>
          <div class="step-body">
            <h3>Scegli il tuo ruolo</h3>
            <p>
              Prenota il tuo posto e ricevi per e-mail la scheda del tuo
              personaggio storico: nome, famiglia, segreti e movente.
            </p>
          </div>
        </div>

        <div class="step-connector">
          <div class="connector-line"></div>
          <span class="connector-gem">◆</span>
          <div class="connector-line"></div>
        </div>

        <div class="step">
          <div class="step-num">II</div>
          <div class="step-body">
            <h3>Il banchetto inizia</h3>
            <p>
              Vesti i panni del tuo personaggio. Parla, inganna, alleati.
              La cena è servita in tre portate — una per atto.
            </p>
          </div>
        </div>

        <div class="step-connector">
          <div class="connector-line"></div>
          <span class="connector-gem">◆</span>
          <div class="connector-line"></div>
        </div>

        <div class="step">
          <div class="step-num">III</div>
          <div class="step-body">
            <h3>Il delitto è compiuto</h3>
            <p>
              Qualcuno cade. Indagini, accuse, rivelazioni. Alla fine
              della serata si scopre la verità — e chi l'ha nascosta.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EVENTI -->
  <section class="section eventi" id="eventi">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Prossimi appuntamenti</span>
        <h2>Gli eventi</h2>
        <div class="divider"><span>⬥</span></div>
      </div>

      <div class="events-grid">
        <article class="event-card featured">
          <div class="event-tag">Prossimo</div>
          <div class="event-theme">Roma · I sec. d.C.</div>
          <h3 class="event-title">La Morte di Lucullus</h3>
          <p class="event-desc">
            Il ricco generale Lucullo è stato trovato morto nel suo triclinium.
            Tra schiavi, senatori e cortigiane, chi ha versato il veleno?
          </p>
          <div class="event-meta">
            <div class="event-info">
              <span class="meta-label">Data</span>
              <span>12 Aprile 2026</span>
            </div>
            <div class="event-info">
              <span class="meta-label">Ospiti</span>
              <span>12 – 20 persone</span>
            </div>
            <div class="event-info">
              <span class="meta-label">Durata</span>
              <span>4 ore</span>
            </div>
          </div>
          <a href="#prenota" class="btn-primary">Prenota ora</a>
        </article>

        <article class="event-card">
          <div class="event-theme">Grecia · V sec. a.C.</div>
          <h3 class="event-title">Il Simposio di Atene</h3>
          <p class="event-desc">
            Un filosofo trovato senza vita dopo una notte di discorsi e vino.
            Socrate aveva ragione: la conoscenza può essere pericolosa.
          </p>
          <div class="event-meta">
            <div class="event-info">
              <span class="meta-label">Data</span>
              <span>7 Giugno 2026</span>
            </div>
            <div class="event-info">
              <span class="meta-label">Ospiti</span>
              <span>10 – 18 persone</span>
            </div>
            <div class="event-info">
              <span class="meta-label">Durata</span>
              <span>4 ore</span>
            </div>
          </div>
          <a href="#prenota" class="btn-ghost">Scopri di più</a>
        </article>

        <article class="event-card">
          <div class="event-theme">Roma · I sec. a.C.</div>
          <h3 class="event-title">Le Idi di Marzo</h3>
          <p class="event-desc">
            La notte prima delle Idi. Cesare è ancora vivo — per ora.
            Pugnali nascosti, giuramenti infranti e un destino già scritto.
          </p>
          <div class="event-meta">
            <div class="event-info">
              <span class="meta-label">Data</span>
              <span>TBA 2026</span>
            </div>
            <div class="event-info">
              <span class="meta-label">Ospiti</span>
              <span>15 – 24 persone</span>
            </div>
            <div class="event-info">
              <span class="meta-label">Durata</span>
              <span>5 ore</span>
            </div>
          </div>
          <a href="#prenota" class="btn-ghost">Lista d'attesa</a>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA PRENOTA -->
  <section class="section prenota" id="prenota">
    <div class="container">
      <div class="prenota-inner">
        <div class="prenota-ornament">
          <span>✦</span>
          <div class="orn-line"></div>
          <span>✦</span>
        </div>
        <span class="section-label">Partecipa</span>
        <h2>Sei pronto a sederti al banchetto?</h2>
        <p>
          Scrivi per prenotare il tuo posto o richiedere informazioni.<br />
          Ogni evento è a numero chiuso.
        </p>
        <a href="mailto:info@mementoconvivium.it" class="btn-primary btn-large">
          Contattaci
        </a>
        <p class="prenota-note">
          Oppure scrivici su <a href="https://instagram.com">Instagram</a>
        </p>
        <div class="prenota-ornament">
          <span>✦</span>
          <div class="orn-line"></div>
          <span>✦</span>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ───────────────────────── */
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: 8rem 2rem 4rem;
  }

  .hero-columns {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 60%;
    display: flex;
    justify-content: space-around;
    align-items: flex-end;
    padding: 0 10%;
    opacity: 0.06;
    pointer-events: none;
  }

  .column {
    width: clamp(40px, 6vw, 80px);
    height: 100%;
    background: linear-gradient(to bottom, var(--cream), transparent);
    position: relative;
  }
  .column::before {
    content: '';
    position: absolute;
    top: 0; left: -30%; right: -30%;
    height: 12%;
    background: var(--cream);
    border-radius: 4px 4px 0 0;
  }
  .column::after {
    content: '';
    position: absolute;
    bottom: 0; left: -40%; right: -40%;
    height: 8%;
    background: var(--cream);
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at center, transparent 30%, rgba(14,13,11,0.7) 100%),
      linear-gradient(to bottom, var(--bg) 0%, transparent 30%, rgba(14,13,11,0.4) 70%, var(--bg) 100%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 750px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    font-weight: 400;
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }
  .hero-title em {
    color: var(--gold-light);
    font-style: italic;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 1.1em;
  }

  .hero-sub {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: var(--cream-dim);
    margin-bottom: 2.5rem;
    line-height: 1.9;
  }
  .hero-sub em { color: var(--gold-light); font-style: italic; }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 2;
    color: var(--gold-dim);
    font-family: var(--font-title);
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--gold-dim), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 1; }
  }

  /* ── Quote ──────────────────────── */
  .quote-section {
    padding: 5rem 0;
    background: var(--bg-2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .quote {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
    position: relative;
  }
  .quote-mark {
    font-family: var(--font-display);
    font-size: 5rem;
    color: var(--gold-dim);
    line-height: 0;
    position: absolute;
    top: 1.5rem; left: -2rem;
    opacity: 0.4;
  }
  .quote p {
    font-size: 1.2rem;
    font-style: italic;
    color: var(--cream);
    line-height: 1.9;
    margin-bottom: 1.2rem;
  }
  .quote p em { color: var(--cream-dim); font-size: 0.95em; }
  .quote cite {
    font-family: var(--font-title);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    font-style: normal;
  }

  /* ── Come funziona ──────────────── */
  .come-funziona { border-top: 1px solid var(--border); }

  .steps {
    display: flex;
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
  }
  .step {
    flex: 1;
    text-align: center;
    padding: 2.5rem 1.5rem;
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: border-color 0.3s;
  }
  .step:hover { border-color: var(--gold-dim); }
  .step-num {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--gold);
    opacity: 0.5;
    margin-bottom: 1rem;
  }
  .step h3 {
    font-size: 1.1rem;
    color: var(--white);
    margin-bottom: 0.75rem;
  }
  .step p { font-size: 0.95rem; color: var(--cream-dim); }

  .step-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 0.5rem;
    gap: 4px;
  }
  .connector-line { width: 1px; height: 30px; background: var(--border); }
  .connector-gem { color: var(--gold); font-size: 0.5rem; opacity: 0.6; }

  /* ── Eventi ─────────────────────── */
  .eventi { border-top: 1px solid var(--border); }

  .events-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5px;
    background: var(--border);
  }
  .event-card {
    background: var(--bg-card);
    padding: 2.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background 0.3s;
  }
  .event-card:hover { background: #1f1c18; }
  .event-card.featured {
    grid-row: 1 / 3;
    border-left: 2px solid var(--gold-dim);
  }

  .event-tag {
    position: absolute;
    top: 1.5rem; right: 1.5rem;
    font-family: var(--font-title);
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--gold);
    padding: 0.2rem 0.6rem;
  }
  .event-theme {
    font-family: var(--font-title);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .event-title {
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    color: var(--white);
    line-height: 1.2;
  }
  .event-desc { color: var(--cream-dim); font-size: 0.95rem; flex: 1; }
  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }
  .event-info {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
  }
  .meta-label {
    font-family: var(--font-title);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold-dim);
  }

  /* ── Prenota ────────────────────── */
  .prenota { border-top: 1px solid var(--border); text-align: center; }
  .prenota-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 600px;
    margin: 0 auto;
  }
  .prenota-inner h2 { font-size: clamp(1.6rem, 3.5vw, 2.4rem); color: var(--white); }
  .prenota-inner > p { color: var(--cream-dim); }
  .prenota-note { font-size: 0.85rem; color: var(--gold-dim); }
  .prenota-note a { color: var(--gold); text-decoration: none; }
  .prenota-note a:hover { text-decoration: underline; }

  .prenota-ornament {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 300px;
    color: var(--gold-dim);
    font-size: 0.5rem;
  }
  .orn-line { flex: 1; height: 1px; background: var(--border); }

  /* ── Responsive ─────────────────── */
  @media (max-width: 768px) {
    .steps { flex-direction: column; }
    .step-connector { flex-direction: row; padding: 0.5rem 0; }
    .connector-line { width: 30px; height: 1px; }
    .events-grid { grid-template-columns: 1fr; }
    .event-card.featured { grid-row: auto; }
    .quote-mark { display: none; }
  }
</style>
